# Host Next.js talking to Compose Postgres (npm run db:up) — mapped to host port 5433
DATABASE_URL="postgresql://aiscrum:aiscrum@localhost:5433/aiscrum"
# Full stack in Docker sets DATABASE_URL=...@db:5432/... inside compose — see docs/DOCKER_LOCAL.md
AUTH_SECRET="change-me-to-a-long-random-string"
# Local: http://localhost:3000 — Railway: https://your-app.up.railway.app
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
CRON_SECRET="dev-cron-secret"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="AI Scrum Master <noreply@localhost>"
OPENAI_API_KEY=
# Set to require when your Postgres needs SSL (Railway). Use disable for local Docker Compose.
# PGSSLMODE=require
# PGSSLMODE=disable
